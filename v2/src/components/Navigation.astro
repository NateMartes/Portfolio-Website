---
const navItems = [
  { label: 'ABOUT', href: '/' },
  { label: 'EXPERIENCE', href: '/experience' },
  { label: 'PROJECTS', href: '/projects' },
  { label: 'BLOG', href: '/blog' },
  { label: 'CONTACT', href: '/contact' }
];

const currentPath = Astro.url.pathname;
---

<nav class="navigation reveal">
  <div class="nav-container">
    <div class="logo">
      <a href="/">NATE<span class="block-cursor"></span></a>
    </div>
    <ul class="nav-links">
      {navItems.map(({ label, href }) => (
        <li>
          <a 
            href={href} 
            class={currentPath === href || (href !== '/' && currentPath.startsWith(href)) ? 'active brutal-border' : 'brutal-border'}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<style>
  .navigation {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    padding: var(--spacing-sm) var(--spacing-md);
    z-index: 100;
    background-color: #000000;
    border-bottom: var(--border-thick) solid var(--text-main);
  }

  .nav-container {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    font-size: 2.5rem;
    line-height: 1;
  }

  .logo a {
    color: var(--text-main);
    display: flex;
    align-items: flex-end;
    gap: 4px;
  }
  
  .logo a:hover {
    background: transparent;
    color: var(--accent-color);
  }

  .block-cursor {
    display: inline-block;
    width: 20px;
    height: 35px;
    background-color: var(--accent-color);
    animation: flashBlock 1s infinite steps(2, end);
  }

  .nav-links {
    display: flex;
    gap: var(--spacing-md);
    list-style: none;
  }

  .nav-links a {
    font-family: var(--font-mono);
    font-size: 1rem;
    padding: 0.5rem 1rem;
    display: inline-block;
    background: var(--bg-color);
    color: var(--text-main);
  }

  .nav-links a.active {
    background: var(--text-main);
    color: var(--bg-color);
    box-shadow: 4px 4px 0px 0px var(--accent-color);
    transform: translate(-4px, -4px);
  }

  .nav-links a:hover {
    background: var(--accent-color);
    color: var(--text-main);
    border-color: var(--accent-color);
  }

  @media (max-width: 900px) {
    .nav-links {
      gap: 0;
    }
    .nav-links a {
      font-size: 0.8rem;
      padding: 0.25rem 0.5rem;
      border-width: var(--border-thin);
    }
    .logo {
      font-size: 1.5rem;
    }
    .block-cursor {
      width: 12px;
      height: 20px;
    }
  }

  @media (max-width: 480px) {
    .nav-container {
      flex-direction: column;
      gap: var(--spacing-sm);
    }
    .nav-links {
      flex-wrap: wrap;
      justify-content: center;
      gap: var(--spacing-sm);
    }
    .nav-links a {
      font-size: 0.75rem;
    }
  }
</style>
