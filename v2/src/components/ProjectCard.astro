---
interface Props {
  name: string;
  link?: string;
  content: string;
  img?: string;
  utilities: string[];
  delay?: number;
}

const { name, link, content, img = "/assets/elementor-placeholder-image.avif", utilities, delay = 1 } = Astro.props;
---

<article class={`project-card brutal-border brutal-shadow reveal delay-${delay}`}>
  <div class="project-header">
    <h3 class="project-title">
      {link ? (
        <a href={link} target="_blank" rel="noopener noreferrer" class="project-link">
          {name} <span class="external-icon">↗</span>
        </a>
      ) : (
        name
      )}
    </h3>
  </div>

  <div class="project-image-container">
    <img src={img} alt={`${name} preview`} loading="lazy" class="project-image" />
    {link ? (
      <a href={link} target="_blank" rel="noopener noreferrer" class="image-overlay">
        <div class="overlay-text">INSPECT</div>
      </a>
    ) : (
      <div class="image-overlay">
        <div class="overlay-text">INSPECT</div>
      </div>
    )}
  </div>

  <div class="project-content">
    <p class="project-description">{content}</p>
    
    <div class="tech-stack">
      {utilities.map(tech => (
        <span class="tech-tag brutal-border">{tech}</span>
      ))}
    </div>
  </div>
</article>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    background: var(--bg-color);
    transition: all 0s;
  }

  .project-card:hover {
    background: var(--accent-color);
  }

  .project-header {
    padding: var(--spacing-md);
    border-bottom: var(--border-thick) solid var(--text-main);
    background: var(--text-main);
  }

  .project-title {
    font-size: 2rem;
    margin: 0;
    color: var(--bg-color);
  }

  .project-link {
    color: var(--bg-color);
    transition: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .project-link:hover {
    background: transparent;
    color: var(--accent-color);
  }

  .external-icon {
    font-family: var(--font-mono);
    font-size: 2.5rem;
    line-height: 0.5;
  }

  .project-image-container {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-bottom: var(--border-thick) solid var(--text-main);
    overflow: hidden;
  }

  .project-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(100%) contrast(1.5);
  }

  .image-overlay {
    position: absolute;
    inset: 0;
    background: var(--accent-color);
    display: none;
    align-items: center;
    justify-content: center;
  }

  .project-card:hover .image-overlay {
    display: flex;
  }

  .overlay-text {
    font-size: 3rem;
    font-weight: 900;
    color: var(--text-main);
    border: var(--border-thick) solid var(--text-main);
    background: var(--bg-color);
    padding: 1rem 2rem;
    transform: rotate(-5deg);
    box-shadow: 8px 8px 0px 0px var(--bg-color);
  }

  .project-content {
    padding: var(--spacing-lg);
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .project-description {
    font-family: var(--font-mono);
    color: var(--text-main);
    font-size: 1rem;
    line-height: 1.5;
    margin-bottom: var(--spacing-xl);
    flex-grow: 1;
  }

  .project-card:hover .project-description {
    color: var(--text-main);
    font-weight: 800;
  }

  .tech-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: auto;
  }

  .tech-tag {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 800;
    padding: 0.25rem 0.5rem;
    background: var(--bg-color);
    color: var(--text-main);
  }

  .project-card:hover .tech-tag {
    background: var(--text-main);
    color: var(--accent-color);
    border-color: var(--bg-color);
  }
</style>
