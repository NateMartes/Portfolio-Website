---
import Layout from '../../layouts/Layout.astro';

// Fetch all markdown posts
let posts: Record<string, any> = []
try {
  posts = await Astro.glob('./*.md');
} catch (e) {
}

// Sort by date descending
const sortedPosts = posts.sort((a, b) => new Date(b.frontmatter.date).valueOf() - new Date(a.frontmatter.date).valueOf());
---

<Layout title="Blog | Nathaniel Martes">
  <div class="page-header reveal delay-1">
    <div class="header-content brutal-border brutal-shadow">
      <h1 class="page-title">Tech_Write_Ups</h1>
      <p class="page-subtitle">KNOWLEDGE & THOUGHTS</p>
    </div>
  </div>

  <section class="blog-container">
    <div class="posts-grid">
      {sortedPosts.map((post, index) => (
        <a href={post.url} class={`post-card brutal-border brutal-shadow reveal delay-${(index % 5) + 1}`}>
          <div class="post-header">
            <h2>{post.frontmatter.title}</h2>
          </div>
          <div class="post-body">
            <p class="description">{post.frontmatter.description}</p>
            <span class="date brutal-border">{post.frontmatter.date}</span>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>

<style>
  .page-header {
    max-width: 1400px;
    margin: 0 auto;
    padding: var(--spacing-xl) var(--spacing-lg);
  }
  
  .header-content {
    background: var(--text-main);
    padding: var(--spacing-xl);
    display: inline-block;
  }

  .page-title {
    font-size: clamp(3rem, 8vw, 6rem);
    color: var(--bg-color);
    margin: 0;
    line-height: 1;
    word-break: break-word;
  }

  .page-subtitle {
    font-family: var(--font-mono);
    color: var(--accent-color);
    font-weight: 800;
    font-size: 1.5rem;
    margin-top: var(--spacing-md);
    background: var(--bg-color);
    display: inline-block;
    padding: 0.5rem 1rem;
    border: var(--border-thick) solid var(--bg-color);
  }

  .blog-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: var(--spacing-xl) var(--spacing-lg) var(--spacing-xxl);
  }

  .posts-grid {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xl);
    max-width: 1000px;
  }

  .post-card {
    display: block;
    background: var(--bg-color);
    color: var(--text-main);
    transition: all 0s;
  }

  .post-card:hover {
    background: var(--accent-color);
    color: var(--text-main);
  }

  .post-header {
    padding: var(--spacing-md) var(--spacing-lg);
    border-bottom: var(--border-thick) solid var(--text-main);
    background: var(--text-main);
  }

  .post-card:hover .post-header {
    background: var(--accent-color);
    border-color: var(--bg-color);
  }

  h2 {
    font-size: 2.5rem;
    margin: 0;
    color: var(--bg-color);
    line-height: 1.1;
  }

  .post-card:hover h2 {
    color: var(--text-main);
  }

  .post-body {
    padding: var(--spacing-lg);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--spacing-md);
  }

  .description {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    line-height: 1.5;
    margin: 0;
  }

  .date {
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 800;
    padding: 0.5rem 1rem;
    background: var(--bg-color);
    color: var(--text-main);
    box-shadow: 4px 4px 0px 0px var(--accent-color);
  }

  .post-card:hover .date {
    background: var(--text-main);
    color: var(--accent-color);
    border-color: var(--bg-color);
    box-shadow: 4px 4px 0px 0px var(--bg-color);
  }

  @media (max-width: 768px) {
    .page-title {
      font-size: clamp(1.5rem, 6vw, 2.5rem);
      line-height: 1;
      white-space: normal;
    }
    .page-subtitle {
      font-size: 1rem;
      white-space: normal;
    }
    .header-content {
      padding: var(--spacing-md);
      width: 100%;
    }
    .page-header {
      padding: var(--spacing-lg) var(--spacing-md);
    }
    .blog-container {
      padding: var(--spacing-md) var(--spacing-md) var(--spacing-xl);
    }
    .post-header {
      padding: var(--spacing-md);
    }
    .post-body {
      padding: var(--spacing-md);
    }
    h2 {
      font-size: 1.8rem;
    }
  }
</style>
