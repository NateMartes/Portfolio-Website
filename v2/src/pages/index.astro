---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Nathaniel Martes">
	<div class="hero-container">
		<header class="hero-header">
			<h1 class="reveal delay-1">NATHANIEL MARTES</h1>
			
			<div class="meta-container reveal delay-3 brutal-border">
				<p class="tagline">REFINING MY DEVELOPER SKILLS,<br/>ONE LINE AT A TIME.</p>
			</div>
		</header>

		<section class="about-section reveal delay-4">
			<div class="about-grid">
				<div class="about-image-placeholder brutal-border brutal-shadow">
					<span><img width=300px src="/assets/1U7A2911.avif"/></span>
				</div>
				<div class="about-content brutal-border brutal-shadow">
					<h2 class="section-title">ABOUT_ME</h2>
					<div class="text-block">
						<p>
							My passion for programming started in high school, where I began by creating simple—and sometimes humorous—platformer games. 
							Those early projects sparked a curiosity that led me to explore the deeper layers of the software world.
						</p>
						<p>
							As I delved further, I realized how integral software is to our daily lives, shaping everything from how we 
							communicate to how we solve complex problems. This journey has not only honed my technical skills but also deepened my understanding of the profound impact that software has on society.
						</p>
						<p>
							My drive to contribute to this ever-evolving field continues to grow as I learn more about its limitless possibilities.
						</p>
					</div>
				</div>
			</div>
		</section>
	</div>
</Layout>

<style>
	.hero-container {
		max-width: 1400px;
		margin: 0 auto;
		padding: var(--spacing-xxl) var(--spacing-lg);
		min-height: calc(100vh - 80px);
		display: flex;
		flex-direction: column;
	}

	.hero-header {
		margin-bottom: var(--spacing-xl);
	}

	h1 {
		font-size: clamp(3rem, 10vw, 10rem);
		line-height: 0.85;
		margin: 0;
		white-space: normal;
		word-break: break-word;
	}

	.meta-container {
		margin-top: var(--spacing-xl);
		padding: var(--spacing-lg);
		display: flex;
		justify-content: space-between;
		align-items: flex-end;
		background: var(--bg-color);
		position: relative;
	}

  .meta-container::before {
    content: '';
    position: absolute;
    top: -15px;
    left: -15px;
    width: 100%;
    height: 100%;
    border: var(--border-thick) solid var(--accent-color);
    z-index: -1;
  }

	.tagline {
		font-family: var(--font-mono);
		font-size: clamp(1rem, 2vw, 1.5rem);
		font-weight: 800;
		max-width: 500px;
	}

	.about-section {
		margin-top: var(--spacing-xxl);
	}

	.about-grid {
		display: grid;
		grid-template-columns: 1fr 1.5fr;
		gap: var(--spacing-xl);
	}

	.about-image-placeholder {
		background: var(--bg-color);
		min-height: 400px;
		display: flex;
		align-items: center;
		justify-content: center;
	}
	
	.about-image-placeholder span {
		font-family: var(--font-mono);
		color: var(--text-muted);
		font-weight: 800;
		font-size: 1.2rem;
	}

	.about-content {
		background: var(--bg-color);
		padding: var(--spacing-xl);
	}

	.section-title {
		font-size: 3rem;
		background: var(--text-main);
		color: var(--bg-color);
		display: inline-block;
		padding: 0 0.5rem;
		margin-bottom: var(--spacing-lg);
	}

	.text-block p {
		font-family: var(--font-mono);
		font-size: 1.1rem;
		margin-bottom: var(--spacing-md);
	}

	.text-block p:last-child {
		margin-bottom: 0;
	}

	@media (max-width: 1024px) {
		.meta-container {
			flex-direction: column;
			align-items: flex-start;
			gap: var(--spacing-lg);
		}
		
		.about-grid {
			grid-template-columns: 1fr;
		}
		
		.about-image-placeholder {
			min-height: 300px;
		}
	}

  @media (max-width: 768px) {
    .hero-container {
      padding: var(--spacing-xl) var(--spacing-md);
    }
    .about-content {
      padding: var(--spacing-md);
    }
    .section-title {
      font-size: 2rem;
    }
  }
</style>
